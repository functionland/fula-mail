# Fula Mail Gateway Configuration
# Copy this file to .env and customize

# ============================================
# Server Settings
# ============================================

MAIL_HOST=0.0.0.0
MAIL_HTTP_PORT=8080
MAIL_SMTP_PORT=25
MAIL_SUBMISSION_PORT=587
MAIL_IMAP_PORT=993

# ============================================
# Database (shared PostgreSQL)
# ============================================
# Uses the same PostgreSQL instance as pinning-service and fula-api.
# Email-only tables are created in the same database.

POSTGRES_HOST=postgres-pinning
POSTGRES_PORT=5432
POSTGRES_DB=pinning_service
POSTGRES_USER=pinning_user
POSTGRES_PASSWORD=change-in-production

# ============================================
# Pinning Service Integration
# ============================================
# Used to store encrypted mail blobs via the existing pinning infrastructure.
# Same service that handles file uploads from FxFiles/FxMail.

PINNING_SERVICE_URL=http://localhost:6000
PINNING_SYSTEM_KEY=your-system-key-here

# ============================================
# TLS Certificates
# ============================================
# Required for SMTP STARTTLS, IMAPS, and HTTPS.
# Use Let's Encrypt or bring your own.

TLS_CERT_PATH=/var/lib/fula-mail/certs/fullchain.pem
TLS_KEY_PATH=/var/lib/fula-mail/certs/privkey.pem

# Auto-provision via ACME (Let's Encrypt)
# ACME_EMAIL=admin@fula.net
# ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory

# ============================================
# Authentication (JWT - same flow as FxFiles)
# ============================================
# FxMail authenticates with the same JWT method as FxFiles.
# The JWT secret must match the one used by fula-api/pinning-service.

JWT_SECRET=your-secret-key-here-change-in-production

# ============================================
# Default MX Hostname
# ============================================
# The hostname that custom domain MX records point to.
# Must have a valid PTR record matching this hostname.

MX_HOSTNAME=mail.fula.net

# ============================================
# Push Notifications
# ============================================
# For Path A: notify client to fetch and encrypt mail locally.
# FCM for Android, APNs for iOS.

# FCM_SERVICE_ACCOUNT_KEY=/var/lib/fula-mail/fcm-key.json
# APNS_CERT_PATH=/var/lib/fula-mail/apns-cert.p12

# ============================================
# Outbound SMTP
# ============================================
# For IP warming, consider using a relay service initially.

# OUTBOUND_RELAY_HOST=smtp.sendgrid.net
# OUTBOUND_RELAY_PORT=587
# OUTBOUND_RELAY_USER=apikey
# OUTBOUND_RELAY_PASSWORD=your-sendgrid-api-key

# ============================================
# Spam Filtering
# ============================================

# RSPAMD_URL=http://rspamd:11333

# ============================================
# Logging
# ============================================

RUST_LOG=info,fula_mail=debug
